{
  "name": "napi-oop-example-add-numbers",
  "version": "0.1.0",
  "private": true,
  "description": "Example: a TypeScript entrypoint calling an out-of-process Rust add_numbers function",
  "main": "dist/main.js",
  "scripts": {
    "build:native": "cargo build --release -p add-numbers-example",
    "build:types": "node ../../packages/runtime/dist/codegen-cli.js ../../target/release/add-numbers-provider ts/generated AddNumbers",
    "build:ts": "tsc",
    "build": "npm run build:native && npm run build:types && npm run build:ts",
    "start": "npm run start:node-parent",
    "start:node-parent": "node dist/main.js",
    "start:rust-parent": "node rust-parent.mjs"
  },
  "dependencies": {
    "napi-oop-runtime": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
