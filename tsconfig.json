{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node20",
    "moduleResolution": "node16",
    "rootDir": "src/ts",
    "outDir": "dist",
    "allowJs": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/ts/**/*.ts", "src/ts/**/*.js"]
}
